---
// Phase-1 placeholder CTA. В Phase 2 сюда подключается форма подписки / продажа PDF-схем.
interface Props {
  title?: string;
  text?: string;
  ctaLabel?: string;
}
const {
  title = 'Безкоштовні схеми вишивки',
  text = 'Незабаром тут зʼявиться добірка безкоштовних схем у форматі PDF та підписка на нові матеріали.',
  ctaLabel = 'Скоро',
} = Astro.props;
---
<aside class="my-8 rounded-xl border border-[var(--color-brand)]/20 bg-[var(--color-paper)] p-5">
  <h2 class="font-display text-lg font-bold text-[var(--color-brand-dark)]">{title}</h2>
  <p class="mt-1 text-stone-700">{text}</p>
  <span class="mt-3 inline-block rounded-lg bg-[var(--color-brand)] px-4 py-2 font-medium text-white opacity-90">{ctaLabel}</span>
</aside>
