---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: ImageMetadata;
  alt: string;
  class?: string;
  loading?: 'eager' | 'lazy';
  widths?: number[];
  sizes?: string;
}
const {
  src,
  alt,
  class: cls,
  loading = 'lazy',
  widths = [400, 800, 1200],
  sizes = '(max-width: 768px) 100vw, 800px',
} = Astro.props;
---
<Image src={src} alt={alt} class={cls} loading={loading} widths={widths} sizes={sizes} format="webp" />
