---
interface Item {
  title: string;
  href: string;
}
interface Props {
  items: Item[];
}
const { items } = Astro.props;
const shown = items.slice(0, 6);
---
{
  shown.length > 0 && (
    <section class="mt-10 border-t border-[var(--color-line)] pt-6">
      <h2 class="h2-section mb-4">Схожі матеріали</h2>
      <ul class="grid gap-3 sm:grid-cols-2">
        {shown.map((it) => (
          <li>
            <a
              href={it.href}
              class="flex items-center gap-2 rounded-lg border border-[var(--color-line)] bg-white px-4 py-3 font-medium text-[var(--color-ink)] transition-colors hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]"
            >
              <span class="x-mark shrink-0" aria-hidden="true">✕</span>
              {it.title}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
