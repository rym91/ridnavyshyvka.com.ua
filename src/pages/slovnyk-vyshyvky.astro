---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Ornament from '../components/Ornament.astro';
import { organizationSchema, breadcrumbSchema } from '../lib/schema';

const site = Astro.site ?? new URL('https://ridnavyshyvka.com.ua');
const url = new URL('/slovnyk-vyshyvky/', site).href;
const crumbs = [
  { name: 'Головна', href: '/' },
  { name: 'Словник термінів', href: '/slovnyk-vyshyvky/' },
];

type Term = { term: string; def: string; more?: { href: string; label: string } };
type Group = { id: string; title: string; terms: Term[] };

const groups: Group[] = [
  {
    id: 'tehniky',
    title: 'Техніки й шви',
    terms: [
      { term: 'Хрестик', def: 'Базовий рахунковий стібок у формі ✕ — дві діагоналі, що перетинаються в одній клітинці канви. З нього складається вся вишивка хрестиком.', more: { href: '/vyshyvka-hrestykom/', label: 'вишивка хрестиком' } },
      { term: 'Півхрестик', def: 'Одна діагональ замість повного хрестика. Ним шиють плавні переходи, тіні й дрібні деталі.' },
      { term: 'Бекстич (контурний шов)', def: 'Тонка лінія рівних стібків «назад голкою», якою обводять контури вже вишитого малюнка. Роблять в останню чергу.' },
      { term: 'Гладь', def: 'Техніка вільної вишивки, де стібки щільно вкладають один до одного, повністю зашиваючи мотив. Дає гладеньку, майже мальовану поверхню.', more: { href: '/tehniky-vyshyvky/vyshyvka-gladdyu/', label: 'вишивка гладдю' } },
      { term: 'Мережка', def: 'Ажурна техніка: з тканини висмикують частину ниток, а ті, що лишилися, стягують у пучки. Утворює прозорий візерунок-«сітку».', more: { href: '/tehniky-vyshyvky/merezhka-vyshyvka/', label: 'мережка' } },
      { term: 'Рішельє', def: 'Біла ажурна вишивка з вирізаними ділянками тканини, з’єднаними містками-бридами. Виглядає як тонке мереживо на полотні.', more: { href: '/tehniky-vyshyvky/bila-vyshyvka-rishelye/', label: 'біла вишивка' } },
      { term: 'Лиштва', def: 'Техніка щільної гладі, характерна для білої вишивки Полтавщини; мотив зашивають рівними паралельними стібками.' },
      { term: 'Монастирський шов', def: 'Один із способів пришивання бісеру, коли кожна намистина лягає діагональним стібком — рівно й щільно, як хрестик.' },
      { term: 'Французький вузлик', def: 'Об’ємна цятка, яку роблять, обмотавши нитку навколо голки. Ним вишивають серединки квітів, очі, дрібні акценти.' },
      { term: 'Протяжка', def: 'Нитка, протягнута з вивороту між віддаленими ділянками одного кольору. Довгих протяжок уникають, щоб не псувати виворіт.' },
    ],
  },
  {
    id: 'materialy',
    title: 'Матеріали та інструменти',
    terms: [
      { term: 'Канва (Аїда)', def: 'Спеціальна тканина з рівномірним переплетенням і чіткими клітинками для рахункових технік. Аїда — найпопулярніший її різновид.', more: { href: '/materialy-dlya-vyshyvky/kanva-dlya-vyshyvky/', label: 'канва для вишивання' } },
      { term: 'Каунт', def: 'Щільність канви — кількість клітинок (або ниток) на дюйм. Аїда 14 = 14 хрестиків на дюйм. Що більший каунт, то дрібніша й меншa робота.', more: { href: '/kalkulyator-rozmiru-vyshyvky/', label: 'калькулятор розміру' } },
      { term: 'Муліне', def: 'Бавовняні нитки для вишивання, скручені з кількох тонких волокон. Зазвичай вишивають у 2 складення; колір має номер за палітрою виробника.', more: { href: '/materialy-dlya-vyshyvky/nytky-muline-dlya-vyshyvky/', label: 'нитки муліне' } },
      { term: 'П’яльці', def: 'Кільце або рамка, що натягують тканину під час роботи. Рівний натяг робить стібки акуратними.', more: { href: '/materialy-dlya-vyshyvky/pyaltsi-dlya-vyshyvannya/', label: 'п’яльці для вишивання' } },
      { term: 'Гобеленова голка', def: 'Голка з тупим кінчиком і великим вушком. Не розщеплює нитки канви, а проходить між ними — головна голка для хрестика.', more: { href: '/materialy-dlya-vyshyvky/golky-dlya-vyshyvannya/', label: 'голки для вишивання' } },
      { term: 'Бленд', def: 'Поєднання двох ниток різних кольорів в одній голці для отримання проміжного відтінку чи переливу.' },
    ],
  },
  {
    id: 'shemy',
    title: 'Схеми',
    terms: [
      { term: 'Схема', def: 'Малюнок на сітці, де кожна клітинка = один хрестик, а символ або колір у ній = певна нитка. За схемою вишивають рахункові техніки.', more: { href: '/vyshyvka-hrestykom/yak-chytaty-shemy-hrestykom/', label: 'як читати схеми' } },
      { term: 'Легенда схеми', def: 'Таблиця-ключ поряд зі схемою: перелік усіх символів, відповідних кольорів та номерів муліне, іноді — кількості мотків.' },
    ],
  },
  {
    id: 'biser',
    title: 'Бісер і прикраси',
    terms: [
      { term: 'Бісер', def: 'Дрібні намистини, якими вишивають або плетуть прикраси. У вишивці бісером кожну намистину пришивають на своє місце за схемою.', more: { href: '/vyshyvka-biserom/', label: 'вишивка бісером' } },
      { term: 'Силянка', def: 'Традиційна українська стрічка-прикраса на шию, зіткана або зшита з бісеру за геометричним візерунком.', more: { href: '/vyshyvka-biserom/sylianky-z-biseru-shemy/', label: 'силянки з бісеру' } },
      { term: 'Гердан', def: 'Вузька плетена стрічка-прикраса з бісеру, часто з підвіскою-медальйоном. Ближчий родич силянки.', more: { href: '/vyshyvka-biserom/herdany-shemy/', label: 'гердани' } },
    ],
  },
  {
    id: 'vyroby',
    title: 'Вироби й традиції',
    terms: [
      { term: 'Оберіг', def: 'Річ із захисним, символічним значенням. Вишиті обереги роблять з увагою до орнаменту й кольору.', more: { href: '/ukrayinska-vyshyvka/vyshyvka-oberih-dlia-voina/', label: 'вишивка-оберіг' } },
      { term: 'Рушник', def: 'Довге вишите полотнище обрядового призначення — весільне, святкове, для ікон. Один із головних символів української вишивки.', more: { href: '/vyshyti-rushnyky/', label: 'вишиті рушники' } },
      { term: 'Вишиванка', def: 'Традиційна українська сорочка з вишивкою на комірі, рукавах і пазусі. Орнамент і крій різняться за регіонами.', more: { href: '/vyshyvanka/', label: 'вишиванка' } },
      { term: 'Орнамент', def: 'Візерунок із повторюваних мотивів — геометричних, рослинних, зооморфних. Несе символіку й вказує на регіон.', more: { href: '/vyshyvanka/ornament-vyshyvanky/', label: 'орнамент вишиванки' } },
    ],
  },
];

const allTerms = groups.flatMap((g) => g.terms);
const jsonld = [
  organizationSchema(site.href),
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: new URL(c.href, site).href }))),
  {
    '@context': 'https://schema.org',
    '@type': 'DefinedTermSet',
    name: 'Словник термінів вишивки',
    url,
    inLanguage: 'uk',
    hasDefinedTerm: allTerms.map((t) => ({ '@type': 'DefinedTerm', name: t.term, description: t.def })),
  },
];
---
<BaseLayout
  title="Словник термінів вишивки — прості пояснення"
  description="Словник термінів вишивки: хрестик, гладь, мережка, каунт, муліне, силянка, гердан та інші поняття простими словами для початківців."
  canonicalPath="/slovnyk-vyshyvky/"
  ogType="website"
  jsonld={jsonld}
  wide
>
  <Breadcrumbs items={crumbs} />
  <article class="prose-uk">
    <h1 class="stitched mb-5 font-display text-3xl font-extrabold leading-tight text-[var(--color-ink)] md:text-4xl">
      Словник термінів вишивки
    </h1>
    <p class="max-w-2xl">
      Короткий довідник основних понять вишивки простими словами. Якщо в гайдах вам трапилося незнайоме слово —
      «каунт», «бекстич», «силянка» — знайдіть його тут.
    </p>

    <nav aria-label="Групи термінів" class="toc mt-5 flex flex-wrap gap-2">
      {
        groups.map((g) => (
          <a
            href={`#${g.id}`}
            class="rounded-full border border-[var(--color-line)] bg-white px-4 py-1.5 text-sm font-medium text-[var(--color-ink)] no-underline transition-colors hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]"
          >
            {g.title}
          </a>
        ))
      }
    </nav>

    {
      groups.map((g) => (
        <section id={g.id} style="scroll-margin-top:5rem" class="mt-10">
          <h2>{g.title}</h2>
          <dl class="lg:columns-2 lg:gap-x-12">
            {g.terms.map((t) => (
              <div class="border-b border-[var(--color-line)] py-4" style="break-inside:avoid">
                <dt class="font-display text-xl font-bold text-[var(--color-ink)]">{t.term}</dt>
                <dd class="mt-1 text-[var(--color-ink-soft)]">
                  {t.def}
                  {t.more && (
                    <>
                      {' '}
                      <a href={t.more.href} class="whitespace-nowrap text-[var(--color-brand)] hover:underline">
                        → {t.more.label}
                      </a>
                    </>
                  )}
                </dd>
              </div>
            ))}
          </dl>
        </section>
      ))
    }

    <p class="mt-10">
      Не знайшли потрібне слово? Напишіть нам на сторінці <a href="/kontakty/">Контакти</a> — доповнимо словник.
    </p>
  </article>
  <Ornament height={18} class="mt-10" />
</BaseLayout>
