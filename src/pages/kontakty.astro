---
import BaseLayout from '../layouts/BaseLayout.astro';
import { organizationSchema, breadcrumbSchema, pageSchema } from '../lib/schema';
const site = Astro.site ?? new URL('https://ridnavyshyvka.com.ua');
const jsonld = [
  organizationSchema(site.href),
  breadcrumbSchema([
    { name: 'Головна', url: site.href },
    { name: 'Контакти', url: new URL('/kontakty/', site).href },
  ]),
  pageSchema(
    'ContactPage',
    {
      name: 'Контакти — Рідна вишивка',
      description: 'Звʼяжіться з командою «Рідна вишивка»: питання, пропозиції, співпраця.',
      url: new URL('/kontakty/', site).href,
    },
    site.href,
  ),
];
---
<BaseLayout
  title="Контакти — Рідна вишивка"
  description="Звʼяжіться з командою «Рідна вишивка»: питання, пропозиції, співпраця. Пишіть нам на електронну пошту."
  canonicalPath="/kontakty/"
  ogType="website"
  jsonld={jsonld}
>
  <article class="prose-uk">
    <h1 class="mb-5 font-display text-3xl font-extrabold text-[var(--color-ink)]">Контакти</h1>

    <p>
      Маєте запитання, знайшли неточність або хочете запропонувати співпрацю? Ми завжди раді зворотному звʼязку.
    </p>

    <h2>Електронна пошта</h2>
    <p>
      Пишіть нам на <a href="mailto:info@ridnavyshyvka.com.ua">info@ridnavyshyvka.com.ua</a> — намагаємось
      відповідати протягом кількох робочих днів.
    </p>

    <h2>З яких питань можна писати</h2>
    <ul>
      <li>уточнення чи виправлення в матеріалах;</li>
      <li>пропозиції тем і гайдів, яких вам бракує;</li>
      <li>співпраця, гостьові матеріали, партнерство;</li>
      <li>питання щодо конфіденційності (див. <a href="/polityka-konfidentsiynosti/">Політику конфіденційності</a>).</li>
    </ul>
  </article>
</BaseLayout>
