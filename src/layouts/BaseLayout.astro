---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Ornament from '../components/Ornament.astro';
import { SECTIONS } from '../lib/sections';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogType?: 'website' | 'article';
  image?: string;
  noindex?: boolean;
  jsonld?: object[];
}
const { title, description, canonicalPath, ogType, image, noindex, jsonld = [] } = Astro.props;
---
<!doctype html>
<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&family=Playfair+Display:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf7f2" />
    <link rel="alternate" type="application/rss+xml" title="Рідна вишивка — нові матеріали" href="/rss.xml" />
    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogType={ogType}
      image={image}
      noindex={noindex}
    />
    {jsonld.length > 0 && <JsonLd data={jsonld} />}
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col font-sans text-[var(--color-ink)]">
    <a
      href="#main"
      class="sr-only rounded bg-[var(--color-brand)] px-3 py-1 text-white focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50"
      >Перейти до вмісту</a
    >
    <header class="relative">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4">
        <a href="/" class="group flex items-baseline gap-2">
          <span class="x-mark text-lg" aria-hidden="true">✕</span>
          <span class="font-display text-2xl font-extrabold tracking-tight text-[var(--color-ink)]">
            Рідна <span class="text-[var(--color-brand)]">вишивка</span>
          </span>
        </a>
        <div class="flex items-center gap-2">
        <nav aria-label="Головне меню" class="hidden flex-wrap gap-x-5 gap-y-1 text-sm font-medium md:flex">
          {
            SECTIONS.map((s) => (
              <a href={`/${s.slug}/`} class="text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-brand)]">
                {s.title}
              </a>
            ))
          }
        </nav>
        <a
          href="/poshuk/"
          aria-label="Пошук на сайті"
          class="flex h-9 w-9 items-center justify-center rounded-lg text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-brand)]"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <line x1="21" y1="21" x2="16.5" y2="16.5" />
          </svg>
        </a>
        <details class="md:hidden">
          <summary
            class="flex cursor-pointer list-none items-center gap-1 rounded-lg border border-[var(--color-line)] px-3 py-2 text-sm font-medium text-[var(--color-ink)]"
            aria-label="Відкрити меню"
          >
            Меню
          </summary>
          <nav
            aria-label="Мобільне меню"
            class="absolute left-0 right-0 top-full z-40 grid gap-0.5 border-y border-[var(--color-line)] bg-white px-4 py-3 shadow-md"
          >
            {
              SECTIONS.map((s) => (
                <a href={`/${s.slug}/`} class="block py-2 text-[var(--color-ink-soft)] hover:text-[var(--color-brand)]">
                  {s.title}
                </a>
              ))
            }
          </nav>
        </details>
        </div>
      </div>
      <Ornament height={14} />
    </header>
    <main id="main" class="mx-auto w-full max-w-3xl flex-1 px-4 py-10">
      <slot />
    </main>
    <footer class="mt-8">
      <Ornament height={14} />
      <div class="bg-[var(--color-paper-2)]">
        <div class="mx-auto max-w-5xl px-4 py-7 text-sm text-[var(--color-ink-soft)]">
          <p class="font-display text-base font-bold text-[var(--color-ink)]">Рідна вишивка</p>
          <p class="mt-1">Українська вишивка: схеми, техніки та орнаменти. © 2026</p>
          <nav aria-label="Розділи сайту" class="mt-3 flex flex-wrap gap-x-4 gap-y-1">
            {
              SECTIONS.map((s) => (
                <a href={`/${s.slug}/`} class="hover:text-[var(--color-brand)]">
                  {s.title}
                </a>
              ))
            }
          </nav>
          <nav aria-label="Інформація про сайт" class="mt-3 flex flex-wrap gap-x-4 gap-y-1 border-t border-[var(--color-line)] pt-3">
            <a href="/pro-nas/" class="hover:text-[var(--color-brand)]">Про нас</a>
            <a href="/avtorka/" class="hover:text-[var(--color-brand)]">Авторка</a>
            <a href="/kalkulyator-rozmiru-vyshyvky/" class="hover:text-[var(--color-brand)]">Калькулятор розміру</a>
            <a href="/kontakty/" class="hover:text-[var(--color-brand)]">Контакти</a>
            <a href="/polityka-konfidentsiynosti/" class="hover:text-[var(--color-brand)]">Політика конфіденційності</a>
            <a href="/umovy-vykorystannya/" class="hover:text-[var(--color-brand)]">Умови використання</a>
          </nav>
        </div>
      </div>
    </footer>
    <CookieConsent />
  </body>
</html>
