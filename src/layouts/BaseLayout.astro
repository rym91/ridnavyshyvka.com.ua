---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import JsonLd from '../components/JsonLd.astro';
import Analytics from '../components/Analytics.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Ornament from '../components/Ornament.astro';
import { SECTIONS } from '../lib/sections';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
  ogType?: 'website' | 'article';
  image?: string;
  noindex?: boolean;
  jsonld?: object[];
  /** Ширший main (max-w-5xl) — для сторінок із сайдбаром (sticky-TOC). */
  wide?: boolean;
}
const { title, description, canonicalPath, ogType, image, noindex, jsonld = [], wide = false } = Astro.props;
---
<!doctype html>
<html lang="uk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href="/fonts/manrope-400-cyrillic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/playfair-700-cyrillic.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf7f2" />
    <link rel="alternate" type="application/rss+xml" title="Рідна вишивка — нові матеріали" href="/rss.xml" />
    <Seo
      title={title}
      description={description}
      canonicalPath={canonicalPath}
      ogType={ogType}
      image={image}
      noindex={noindex}
    />
    {jsonld.length > 0 && <JsonLd data={jsonld} />}
    <Analytics />
  </head>
  <body class="flex min-h-screen flex-col font-sans text-[var(--color-ink)]">
    <a
      href="#main"
      class="sr-only rounded bg-[var(--color-brand)] px-3 py-1 text-white focus:not-sr-only focus:absolute focus:left-2 focus:top-2 focus:z-50"
      >Перейти до вмісту</a
    >
    <header class="relative">
      <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
        <a href="/" class="group flex items-baseline gap-2">
          <span class="x-mark text-lg" aria-hidden="true">✕</span>
          <span class="font-display text-2xl font-extrabold tracking-tight text-[var(--color-ink)]">
            Рідна <span class="text-[var(--color-brand)]">вишивка</span>
          </span>
        </a>
        <div class="flex items-center gap-2">
        <nav aria-label="Головне меню" class="hidden flex-wrap gap-x-4 gap-y-1 text-[13px] font-medium md:flex">
          {
            SECTIONS.map((s) => (
              <a href={`/${s.slug}/`} class="whitespace-nowrap py-1 text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-brand)]">
                {s.title}
              </a>
            ))
          }
        </nav>
        <a
          href="/poshuk/"
          aria-label="Пошук на сайті"
          class="flex h-11 w-11 items-center justify-center rounded-lg text-[var(--color-ink-soft)] transition-colors hover:text-[var(--color-brand)]"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="7" />
            <line x1="21" y1="21" x2="16.5" y2="16.5" />
          </svg>
        </a>
        <details class="menu-toggle md:hidden">
          <summary
            class="flex cursor-pointer list-none items-center gap-1 rounded-lg border border-[var(--color-line)] px-3 py-2.5 text-sm font-medium text-[var(--color-ink)]"
            aria-label="Відкрити меню"
          >
            Меню
          </summary>
          <nav
            aria-label="Мобільне меню"
            class="absolute left-0 right-0 top-full z-40 grid gap-0.5 border-y border-[var(--color-line)] bg-white px-4 py-3 shadow-md"
          >
            {
              SECTIONS.map((s) => (
                <a href={`/${s.slug}/`} class="block py-2 text-[var(--color-ink-soft)] hover:text-[var(--color-brand)]">
                  {s.title}
                </a>
              ))
            }
            <div class="mt-1 border-t border-[var(--color-line)] pt-2">
              <a href="/kalkulyator-rozmiru-vyshyvky/" class="block py-2 text-[var(--color-ink-soft)] hover:text-[var(--color-brand)]">🧮 Калькулятор розміру</a>
              <a href="/slovnyk-vyshyvky/" class="block py-2 text-[var(--color-ink-soft)] hover:text-[var(--color-brand)]">📖 Словник термінів</a>
            </div>
          </nav>
        </details>
        </div>
      </div>
      <Ornament height={14} />
    </header>
    <main id="main" class:list={['mx-auto w-full flex-1 px-4 py-10', wide ? 'max-w-5xl' : 'max-w-3xl']}>
      <slot />
    </main>
    <footer class="mt-8">
      <Ornament height={14} />
      <div class="bg-[var(--color-ink)] text-[#c9c0b4]">
        <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 text-sm sm:grid-cols-[1.4fr_1fr_1fr]">
          <div>
            <p class="font-display text-lg font-bold text-[var(--color-paper)]">
              <span class="text-[#ff8fa0]" aria-hidden="true">✕</span> Рідна вишивка
            </p>
            <p class="mt-2 max-w-xs leading-relaxed">
              Українська вишивка: схеми, техніки та орнаменти — від першого стібка до власної вишиванки.
            </p>
            <p class="mt-4">
              Слідкуйте: <a href="https://www.pinterest.com/221rsgnveewbcgma13t7praynn2bnm/" target="_blank" rel="noopener" class="inline-block py-1.5 font-medium text-[#ff8fa0] hover:underline">Pinterest</a> · <a href="/rss.xml" class="inline-block py-1.5 font-medium text-[#ff8fa0] hover:underline">RSS</a>
            </p>
          </div>
          <nav aria-label="Розділи сайту">
            <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-paper)]">Розділи</p>
            <ul class="grid gap-0">
              {
                SECTIONS.map((s) => (
                  <li>
                    <a href={`/${s.slug}/`} class="inline-block py-1.5 hover:text-[#ff8fa0]">
                      {s.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>
          <nav aria-label="Інформація про сайт">
            <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-[var(--color-paper)]">Про сайт</p>
            <ul class="grid gap-0">
              <li><a href="/pro-nas/" class="inline-block py-1.5 hover:text-[#ff8fa0]">Про нас</a></li>
              <li><a href="/avtorka/" class="inline-block py-1.5 hover:text-[#ff8fa0]">Авторка</a></li>
              <li><a href="/kalkulyator-rozmiru-vyshyvky/" class="inline-block py-1.5 hover:text-[#ff8fa0]">Калькулятор розміру</a></li>
              <li><a href="/slovnyk-vyshyvky/" class="inline-block py-1.5 hover:text-[#ff8fa0]">Словник термінів</a></li>
              <li><a href="/kontakty/" class="inline-block py-1.5 hover:text-[#ff8fa0]">Контакти</a></li>
            </ul>
          </nav>
        </div>
        <div class="border-t border-white/10">
          <div class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-4 px-4 py-3 text-xs text-[#8f887d]">
            <span>© 2026 Рідна вишивка</span>
            <a href="/polityka-konfidentsiynosti/" class="inline-block py-1 hover:text-[#ff8fa0]">Політика конфіденційності</a>
            <a href="/umovy-vykorystannya/" class="inline-block py-1 hover:text-[#ff8fa0]">Умови використання</a>
          </div>
        </div>
      </div>
    </footer>
    <CookieConsent />
  </body>
</html>
