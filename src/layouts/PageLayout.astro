---
import { getCollection, type CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import RelatedLinks from '../components/RelatedLinks.astro';
import LeadMagnet from '../components/LeadMagnet.astro';
import Picture from '../components/Picture.astro';
import { getSection } from '../lib/sections';
import { entryUrl, relatedPages } from '../lib/links';
import { articleSchema, breadcrumbSchema, collectionPageSchema, faqSchema } from '../lib/schema';
import Ornament from '../components/Ornament.astro';

interface Props {
  page: CollectionEntry<'pages'>;
  sectionPages?: CollectionEntry<'pages'>[];
  headings?: { depth: number; slug: string; text: string }[];
}
const { page, sectionPages = [], headings = [] } = Astro.props;
const d = page.data;
const section = getSection(d.section);
const path = entryUrl(page);
const site = Astro.site ?? new URL('https://ridnavyshyvka.com.ua');
const absUrl = new URL(path, site).href;

// Абсолютний URL оптимізованого hero для JSON-LD (image), якщо є.
const heroAbs = d.hero ? new URL((await getImage({ src: d.hero })).src, site).href : undefined;

const allPages = await getCollection('pages', (p) => (import.meta.env.PROD ? !p.data.draft : true));
const related = relatedPages(page, allPages);

// Зміст статті (тільки h2).
const toc = headings.filter((h) => h.depth === 2);

// Попередня / наступна стаття в розділі (для не-pillar).
const sectionArticles = allPages
  .filter((p) => p.data.section === d.section && p.data.page_type !== 'pillar')
  .sort((a, b) => a.data.priority.localeCompare(b.data.priority) || a.data.h1.localeCompare(b.data.h1, 'uk'));
const curIdx = sectionArticles.findIndex((p) => p.data.slug === d.slug);
const prevPage = curIdx > 0 ? sectionArticles[curIdx - 1] : null;
const nextPage = curIdx >= 0 && curIdx < sectionArticles.length - 1 ? sectionArticles[curIdx + 1] : null;

const crumbs = [{ name: 'Головна', href: '/' }];
if (section) crumbs.push({ name: section.title, href: `/${section.slug}/` });
if (d.page_type !== 'pillar') crumbs.push({ name: d.h1, href: path });

// pillar = страница-хаб раздела (агрегує матеріали) → CollectionPage; решта → Article.
const isHub = d.page_type === 'pillar';
const jsonld: object[] = [
  breadcrumbSchema(crumbs.map((c) => ({ name: c.name, url: new URL(c.href, site).href }))),
  isHub
    ? collectionPageSchema(
        {
          headline: d.h1,
          description: d.meta_description,
          url: absUrl,
          image: heroAbs,
          dateModified: d.updated?.toISOString(),
        },
        site.href,
      )
    : articleSchema(
        {
          headline: d.h1,
          description: d.meta_description,
          url: absUrl,
          image: heroAbs,
          datePublished: d.updated?.toISOString(),
          dateModified: d.updated?.toISOString(),
        },
        site.href,
      ),
];
if (d.faq.length > 0) jsonld.push(faqSchema(d.faq));

// Дата оновлення українською (без залежності від ICU).
const MONTHS_UK = [
  'січня', 'лютого', 'березня', 'квітня', 'травня', 'червня',
  'липня', 'серпня', 'вересня', 'жовтня', 'листопада', 'грудня',
];
const updatedLabel = d.updated
  ? `${d.updated.getUTCDate()} ${MONTHS_UK[d.updated.getUTCMonth()]} ${d.updated.getUTCFullYear()}`
  : null;

// Phase 1: скрыт (пока нет реальных схем/подписки — не показываем «Скоро»-заглушку). Включим в Phase 2.
const showLeadMagnet = false;
---
<BaseLayout
  title={d.title}
  description={d.meta_description}
  canonicalPath={path}
  ogType="article"
  noindex={d.noindex}
  jsonld={jsonld}
  wide={toc.length >= 3}
>
  <Breadcrumbs items={crumbs} />
  <div class:list={[toc.length >= 3 && 'lg:grid lg:grid-cols-[minmax(0,42rem)_15rem] lg:gap-12']}>
  <div class="min-w-0">
  <article class="prose-uk">
    <h1 class="stitched mb-4 font-display text-3xl font-extrabold leading-tight text-[var(--color-ink)] md:text-4xl">{d.h1}</h1>
    <p class="mb-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-[var(--color-ink-soft)]">
      <a href="/avtorka/" rel="author" class="font-medium text-[var(--color-ink)] hover:text-[var(--color-brand)]">Тетяна Римарьова</a>
      {updatedLabel && (
        <>
          <span aria-hidden="true">·</span>
          <span>Оновлено <time datetime={d.updated!.toISOString()}>{updatedLabel}</time></span>
        </>
      )}
    </p>
    {
      d.summary && (
        <div class="toc mb-6 rounded-xl border-l-4 border-[var(--color-brand)] bg-[var(--color-paper-2)] p-4">
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-brand)]">Коротка відповідь</p>
          <p class="mt-1 text-[var(--color-ink)]">{d.summary}</p>
        </div>
      )
    }
    {d.hero && d.hero_alt && <Picture src={d.hero} alt={d.hero_alt} loading="eager" class="w-full rounded-lg" />}
    {
      d.hero && heroAbs && (
        <p class="mt-2 mb-0 text-right">
          <a
            href={`https://www.pinterest.com/pin/create/button/?url=${encodeURIComponent(absUrl)}&media=${encodeURIComponent(heroAbs)}&description=${encodeURIComponent(d.h1)}`}
            target="_blank"
            rel="noopener nofollow"
            class="inline-flex items-center gap-1.5 py-2 text-sm font-medium text-[var(--color-brand)] no-underline hover:underline"
          >
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.08 3.16 9.43 7.63 11.18-.11-.95-.2-2.4.04-3.44.22-.93 1.4-5.94 1.4-5.94s-.36-.71-.36-1.76c0-1.65.96-2.88 2.15-2.88 1.01 0 1.5.76 1.5 1.67 0 1.02-.65 2.55-.98 3.96-.28 1.18.59 2.14 1.76 2.14 2.11 0 3.73-2.22 3.73-5.43 0-2.84-2.04-4.83-4.96-4.83-3.38 0-5.36 2.53-5.36 5.15 0 1.02.39 2.11.88 2.71.1.12.11.22.08.34l-.33 1.34c-.05.22-.17.26-.4.16-1.5-.7-2.43-2.88-2.43-4.64 0-3.77 2.74-7.24 7.9-7.24 4.15 0 7.38 2.96 7.38 6.91 0 4.13-2.6 7.45-6.21 7.45-1.21 0-2.35-.63-2.74-1.37l-.75 2.85c-.27 1.04-1 2.35-1.49 3.15 1.12.35 2.31.53 3.54.53 6.63 0 12-5.37 12-12S18.63 0 12 0z"/></svg>
            Зберегти в Pinterest
          </a>
        </p>
      )
    }
    {
      toc.length >= 3 && (
        <div id="zmist" class="toc my-6" style="scroll-margin-top:5rem">
          <details class="rounded-xl border border-[var(--color-line)] bg-[var(--color-paper-2)] p-4 lg:hidden">
            <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wide text-[var(--color-ink-soft)]">Зміст статті ▾</summary>
            <ul class="mt-2 grid gap-0 text-sm">
              {toc.map((h) => (
                <li>
                  <a href={`#${h.slug}`} class="text-[var(--color-brand)] hover:underline">{h.text}</a>
                </li>
              ))}
            </ul>
          </details>
        </div>
      )
    }
    {
      ['vyshyvka-hrestykom', 'materialy-dlya-vyshyvky'].includes(d.section) && (
        <aside class="toc my-6 rounded-xl border border-[var(--color-line)] bg-white p-4 text-sm text-[var(--color-ink-soft)]">
          🧮 Не знаєте, скільки тканини потрібно?
          <a href="/kalkulyator-rozmiru-vyshyvky/" class="font-medium text-[var(--color-brand)] hover:underline">Калькулятор розміру вишивки →</a>
        </aside>
      )
    }
    <slot />
    {
      d.faq.length > 0 && (
        <section class="mt-10">
          <h2>Часті запитання</h2>
          <div class="mt-4 overflow-hidden rounded-xl border border-[var(--color-line)] bg-white">
            {d.faq.map((f, i) => (
              <details class="faq-item border-t border-[var(--color-line)] first:border-t-0" open={i === 0}>
                <summary class="flex cursor-pointer items-center justify-between gap-3 px-4 py-3 font-semibold text-[var(--color-ink)]">
                  <span>{f.q}</span>
                  <span class="faq-plus shrink-0 text-xl leading-none text-[var(--color-brand)]" aria-hidden="true">+</span>
                </summary>
                <div class="px-4 pb-4 text-[var(--color-ink)]">{f.a}</div>
              </details>
            ))}
          </div>
        </section>
      )
    }
  </article>
  {
    toc.length >= 3 && (
      <a href="#zmist" class="inline-block py-2 text-sm text-[var(--color-brand)] hover:underline lg:hidden">↑ До змісту</a>
    )
  }
  <Ornament height={18} class="mt-10" />
  {showLeadMagnet && <LeadMagnet />}
  {
    d.page_type === 'pillar' && sectionPages.length > 0 && (
      <section class="mt-8">
        <h2 class="h2-section mb-3">Матеріали розділу</h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {sectionPages.map((p) => (
            <li>
              <a href={entryUrl(p)} class="text-[var(--color-brand)] hover:underline">
                {p.data.h1}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )
  }
  {
    d.page_type !== 'pillar' && (prevPage || nextPage) && (
      <nav aria-label="Навігація розділом" class="mt-10 grid gap-3 sm:grid-cols-2">
        {prevPage && (
          <a
            href={entryUrl(prevPage)}
            class:list={['group rounded-lg border border-[var(--color-line)] bg-white p-3 transition-colors hover:border-[var(--color-brand)]', !nextPage && 'sm:col-span-2']}
          >
            <span class="block text-xs uppercase tracking-wide text-[var(--color-ink-soft)]">← Попередня</span>
            <span class="mt-1 block font-medium text-[var(--color-ink)] group-hover:text-[var(--color-brand)]">
              {prevPage.data.h1}
            </span>
          </a>
        )}
        {nextPage && (
          <a
            href={entryUrl(nextPage)}
            class:list={['group rounded-lg border border-[var(--color-line)] bg-white p-3 text-right transition-colors hover:border-[var(--color-brand)]', !prevPage && 'sm:col-span-2']}
          >
            <span class="block text-xs uppercase tracking-wide text-[var(--color-ink-soft)]">Наступна →</span>
            <span class="mt-1 block font-medium text-[var(--color-ink)] group-hover:text-[var(--color-brand)]">
              {nextPage.data.h1}
            </span>
          </a>
        )}
      </nav>
    )
  }
  <RelatedLinks items={related.map((p) => ({ title: p.data.h1, href: entryUrl(p) }))} />
  </div>
  {
    toc.length >= 3 && (
      <aside class="toc hidden lg:block">
        <div class="lg:sticky lg:top-8">
          <nav aria-label="Зміст статті" class="rounded-xl border border-[var(--color-line)] bg-[var(--color-paper-2)] p-4">
            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-[var(--color-ink-soft)]">Зміст</p>
            <ul class="grid gap-0 text-sm">
              {toc.map((h) => (
                <li>
                  <a href={`#${h.slug}`} class="text-[var(--color-brand)] hover:underline">{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )
  }
  </div>
</BaseLayout>
